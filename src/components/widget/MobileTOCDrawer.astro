---
import type { MarkdownHeading } from "astro";
import { Icon } from "astro-icon/components";
import TOC from "./TOC.astro";

interface Props {
	headings: MarkdownHeading[];
}

const { headings = [] } = Astro.props;
---

<mobile-toc-drawer class="mobile-toc-drawer xl:hidden" aria-hidden="true">
    <div class="mobile-toc-drawer__backdrop" data-mobile-toc-close></div>
    <aside
        class="mobile-toc-drawer__panel card-base"
        role="dialog"
        aria-modal="true"
        aria-labelledby="mobile-toc-title"
        tabindex="-1"
    >
        <header class="mobile-toc-drawer__header">
            <div id="mobile-toc-title" class="text-base font-bold text-black/75 dark:text-white/75">&#30446;&#24405;</div>
            <button
                type="button"
                class="btn-plain scale-animation rounded-lg h-10 w-10 active:scale-90"
                aria-label="Close Table of Contents"
                data-mobile-toc-close
            >
                <Icon name="material-symbols:close-rounded" class="text-[1.35rem]"></Icon>
            </button>
        </header>
        <div data-toc-scroll-root class="toc-inner-wrapper mobile-toc-drawer__scroll hide-scrollbar">
            <div class="h-5 w-full"></div>
            <TOC headings={headings}></TOC>
            <div class="h-8 w-full"></div>
        </div>
    </aside>
</mobile-toc-drawer>

<style>
.mobile-toc-drawer {
    position: fixed;
    inset: 0;
    z-index: 80;
    pointer-events: none;
}

.mobile-toc-drawer__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.28);
    opacity: 0;
    transition: opacity 0.22s ease;
}

.mobile-toc-drawer__panel {
    position: absolute;
    top: 0;
    right: 0;
    width: min(84vw, 22rem);
    max-width: calc(100vw - 2rem);
    height: 100%;
    border-radius: var(--radius-large) 0 0 var(--radius-large);
    box-shadow: -20px 0 50px rgba(0, 0, 0, 0.14);
    transform: translateX(100%);
    transition: transform 0.24s ease;
}

.mobile-toc-drawer__panel:focus {
    outline: none;
}

.mobile-toc-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 4.5rem;
    padding: max(0.75rem, env(safe-area-inset-top)) 1rem 0.5rem 1.25rem;
    border-bottom: 1px dashed var(--line-divider);
}

.mobile-toc-drawer__scroll {
    height: calc(100% - 4.5rem);
    overflow-x: hidden;
    overflow-y: auto;
    padding: 0 0.75rem;
}

.mobile-toc-drawer[data-open="true"] {
    pointer-events: auto;
}

.mobile-toc-drawer[data-open="true"] .mobile-toc-drawer__backdrop {
    opacity: 1;
}

.mobile-toc-drawer[data-open="true"] .mobile-toc-drawer__panel {
    transform: translateX(0);
}

html.dark .mobile-toc-drawer__backdrop {
    background: rgba(0, 0, 0, 0.46);
}
</style>

<style is:global>
html:has(mobile-toc-drawer[data-open="true"]) #top-row {
    z-index: 20;
}
</style>

<script>
import { shouldOpenMobileTocDrawer } from "../../utils/mobile-toc-gesture";

class MobileTocDrawer extends HTMLElement {
    postContainer: HTMLElement | null = null;
    panel: HTMLElement | null = null;
    pointerId: number | null = null;
    trackingTouch = false;
    startX = 0;
    startY = 0;
    currentX = 0;
    currentY = 0;
    previousBodyOverflow: string | null = null;
    previousDocumentOverflow: string | null = null;
    mobileViewport = window.matchMedia("(max-width: 1279px)");

    connectedCallback() {
        this.postContainer = document.getElementById("post-container");
        this.panel = this.querySelector<HTMLElement>(".mobile-toc-drawer__panel");

        this.addEventListener("click", this.handleClick);
        this.postContainer?.addEventListener("pointerdown", this.handlePointerDown);
        this.postContainer?.addEventListener("touchstart", this.handleTouchStart, { passive: true });
        window.addEventListener("pointermove", this.handlePointerMove, { passive: true });
        window.addEventListener("pointerup", this.handlePointerEnd);
        window.addEventListener("pointercancel", this.handlePointerEnd);
        window.addEventListener("touchmove", this.handleTouchMove, { passive: true });
        window.addEventListener("touchend", this.handleTouchEnd);
        window.addEventListener("touchcancel", this.handleTouchEnd);
    }

    disconnectedCallback() {
        this.close();
        this.removeEventListener("click", this.handleClick);
        this.postContainer?.removeEventListener("pointerdown", this.handlePointerDown);
        this.postContainer?.removeEventListener("touchstart", this.handleTouchStart);
        window.removeEventListener("pointermove", this.handlePointerMove);
        window.removeEventListener("pointerup", this.handlePointerEnd);
        window.removeEventListener("pointercancel", this.handlePointerEnd);
        window.removeEventListener("touchmove", this.handleTouchMove);
        window.removeEventListener("touchend", this.handleTouchEnd);
        window.removeEventListener("touchcancel", this.handleTouchEnd);
    }

    handleClick = (event: MouseEvent) => {
        const target = event.target;
        if (!(target instanceof Element)) return;

        if (target.closest("[data-mobile-toc-close]")) {
            this.close();
            return;
        }

        if (target.closest("a[href^='#']")) {
            this.close();
        }
    };

    handleKeyDown = (event: KeyboardEvent) => {
        if (event.key === "Escape") {
            this.close();
        }
    };

    handlePointerDown = (event: PointerEvent) => {
        if (!this.mobileViewport.matches) return;
        if (this.isOpen()) return;
        if (event.pointerType === "mouse") return;
        if (this.shouldIgnoreSwipeTarget(event.target)) return;

        this.pointerId = event.pointerId;
        this.startX = event.clientX;
        this.startY = event.clientY;
        this.currentX = event.clientX;
        this.currentY = event.clientY;
    };

    handlePointerMove = (event: PointerEvent) => {
        if (this.pointerId !== event.pointerId) return;

        this.currentX = event.clientX;
        this.currentY = event.clientY;

        if (!shouldOpenMobileTocDrawer({
            startX: this.startX,
            startY: this.startY,
            currentX: this.currentX,
            currentY: this.currentY,
            viewportWidth: window.innerWidth,
        })) {
            return;
        }

        this.open();
        this.clearGestureTracking();
    };

    handlePointerEnd = (event: PointerEvent) => {
        if (this.pointerId === event.pointerId) {
            this.clearPointer();
        }
    };

    handleTouchStart = (event: TouchEvent) => {
        if (!this.mobileViewport.matches) return;
        if (this.isOpen()) return;
        if (event.touches.length !== 1) return;
        if (this.shouldIgnoreSwipeTarget(event.target)) return;

        const touch = event.touches[0];
        this.trackingTouch = true;
        this.startX = touch.clientX;
        this.startY = touch.clientY;
        this.currentX = touch.clientX;
        this.currentY = touch.clientY;
    };

    handleTouchMove = (event: TouchEvent) => {
        if (!this.trackingTouch) return;
        if (event.touches.length !== 1) {
            this.clearTouch();
            return;
        }

        const touch = event.touches[0];
        this.currentX = touch.clientX;
        this.currentY = touch.clientY;

        if (!shouldOpenMobileTocDrawer({
            startX: this.startX,
            startY: this.startY,
            currentX: this.currentX,
            currentY: this.currentY,
            viewportWidth: window.innerWidth,
        })) {
            return;
        }

        this.open();
        this.clearGestureTracking();
    };

    handleTouchEnd = () => {
        this.clearTouch();
    };

    shouldIgnoreSwipeTarget(target: EventTarget | null) {
        if (!(target instanceof Element)) return true;

        return !!target.closest([
            "a",
            "button",
            "input",
            "textarea",
            "select",
            "summary",
            "label",
            "img",
            "picture",
            "video",
            "iframe",
            "canvas",
            "pre",
            "code",
            "table",
            ".expressive-code",
            ".katex-display-container",
            ".katex-display",
            ".copy-btn",
            "[data-mobile-toc-ignore-swipe]",
        ].join(","));
    }

    open() {
        if (this.isOpen() || !this.mobileViewport.matches) return;

        this.dataset.open = "true";
        this.setAttribute("aria-hidden", "false");
        this.lockScroll();
        document.addEventListener("keydown", this.handleKeyDown);
        this.panel?.focus({ preventScroll: true });
    }

    close() {
        if (!this.isOpen()) return;

        delete this.dataset.open;
        this.setAttribute("aria-hidden", "true");
        document.removeEventListener("keydown", this.handleKeyDown);
        this.unlockScroll();
        this.clearGestureTracking();
    }

    isOpen() {
        return this.dataset.open === "true";
    }

    clearPointer() {
        this.pointerId = null;
    }

    clearTouch() {
        this.trackingTouch = false;
    }

    clearGestureTracking() {
        this.clearPointer();
        this.clearTouch();
    }

    lockScroll() {
        if (this.previousBodyOverflow !== null) return;

        this.previousBodyOverflow = document.body.style.overflow;
        this.previousDocumentOverflow = document.documentElement.style.overflow;
        document.body.style.overflow = "hidden";
        document.documentElement.style.overflow = "hidden";
    }

    unlockScroll() {
        if (this.previousBodyOverflow === null) return;

        document.body.style.overflow = this.previousBodyOverflow;
        document.documentElement.style.overflow = this.previousDocumentOverflow ?? "";
        this.previousBodyOverflow = null;
        this.previousDocumentOverflow = null;
    }
}

if (!customElements.get("mobile-toc-drawer")) {
    customElements.define("mobile-toc-drawer", MobileTocDrawer);
}
</script>
