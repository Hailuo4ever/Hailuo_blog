<style is:global>
hailuo-audio-player {
	position: relative;
	z-index: 2;
	display: block;
	margin: 1.25rem 0 1.75rem;
}

.hailuo-audio-player {
	--player-progress: 0%;
	--player-volume: 100%;
	position: relative;
	display: grid;
	grid-template-columns: auto minmax(0, 1fr) auto;
	grid-template-rows: auto auto;
	column-gap: 1.45rem;
	row-gap: 0.45rem;
	align-items: center;
	min-height: 5.75rem;
	padding: 0.85rem 1.6rem 1rem 0.85rem;
	border: 1px solid rgba(255, 255, 255, 0.62);
	border-radius: 999px;
	background: rgba(255, 255, 255, 0.82);
	box-shadow:
		0 18px 40px rgba(15, 23, 42, 0.08),
		inset 0 1px 0 rgba(255, 255, 255, 0.8);
	color: #3d3d42;
	backdrop-filter: blur(18px) saturate(1.25);
	overflow: hidden;
}

.hailuo-audio-player__cover {
	position: relative;
	z-index: 1;
	height: 4rem;
	max-width: min(8rem, 34vw);
	aspect-ratio: var(--cover-aspect-ratio, 1 / 1);
	grid-row: 1 / 3;
	align-self: center;
	overflow: hidden;
	border: 1px solid rgba(255, 255, 255, 0.72);
	border-radius: 0.875rem;
	background: rgba(255, 255, 255, 0.5);
	box-shadow: 0 8px 18px rgba(15, 23, 42, 0.1);
}

.hailuo-audio-player .hailuo-audio-player__cover img {
	display: block;
	width: 100%;
	height: 100%;
	max-width: none;
	margin: 0;
	object-fit: cover;
	pointer-events: none;
	cursor: default;
}

.hailuo-audio-player__cover-fallback {
	display: grid;
	width: 100%;
	height: 100%;
	place-items: center;
	color: #5b5b60;
	font-weight: 800;
	font-size: 1.35rem;
}

.hailuo-audio-player__main {
	position: relative;
	z-index: 1;
	grid-column: 2;
	grid-row: 1;
	min-width: 0;
}

.hailuo-audio-player__meta {
	min-width: 0;
}

.hailuo-audio-player__title {
	overflow: hidden;
	color: #36363b;
	font-weight: 520;
	font-size: 1.45rem;
	line-height: 1.18;
	text-overflow: ellipsis;
	white-space: nowrap;
}

.hailuo-audio-player__time-row {
	display: flex;
	align-items: center;
	gap: 0;
	margin-top: 0.55rem;
	overflow: hidden;
}

.hailuo-audio-player__time,
.hailuo-audio-player__time-divider {
	color: #626269;
	font-variant-numeric: tabular-nums;
	font-size: 1.2rem;
	font-weight: 500;
	line-height: 1;
	white-space: nowrap;
}

.hailuo-audio-player__controls {
	position: relative;
	z-index: 1;
	display: flex;
	grid-column: 3;
	grid-row: 1;
	align-items: center;
	justify-content: flex-end;
	gap: 2rem;
	min-width: 19.5rem;
}

.hailuo-audio-player__button {
	display: inline-grid;
	width: 2.75rem;
	height: 2.75rem;
	padding: 0;
	border: 0;
	background: transparent;
	color: #57575c;
	place-items: center;
	cursor: pointer;
	transition:
		color 150ms ease,
		opacity 150ms ease,
		transform 150ms ease;
}

.hailuo-audio-player__button svg {
	display: block;
	width: 2.25rem;
	height: 2.25rem;
	stroke-width: 1.9;
}

.hailuo-audio-player__button:hover:not(:disabled) {
	color: #34343a;
	transform: translateY(-1px);
}

.hailuo-audio-player__button:active:not(:disabled) {
	transform: translateY(0) scale(0.96);
}

.hailuo-audio-player__button:disabled {
	cursor: default;
	opacity: 0.62;
}

.hailuo-audio-player__button.is-loading {
	cursor: wait;
	opacity: 0.48;
}

.hailuo-audio-player__button.is-playing {
	color: #55555a;
}

.hailuo-audio-player__progress {
	position: relative;
	z-index: 2;
	display: block;
	grid-column: 2;
	grid-row: 2;
	align-self: center;
	width: 100%;
	height: 0.125rem;
	border-radius: 999px;
	appearance: none;
	background: linear-gradient(
		to right,
		rgba(86, 86, 92, 0.7) 0 var(--player-progress),
		rgba(86, 86, 92, 0.18) var(--player-progress) 100%
	);
	cursor: pointer;
	opacity: 0.55;
	transition: opacity 150ms ease;
}

.hailuo-audio-player__progress::-webkit-slider-thumb {
	width: 0.75rem;
	height: 0.75rem;
	border: 0;
	border-radius: 999px;
	appearance: none;
	background: rgba(86, 86, 92, 0.85);
	opacity: 0;
	transition: opacity 150ms ease;
}

.hailuo-audio-player__progress::-moz-range-thumb {
	width: 0.75rem;
	height: 0.75rem;
	border: 0;
	border-radius: 999px;
	background: rgba(86, 86, 92, 0.85);
	opacity: 0;
	transition: opacity 150ms ease;
}

.hailuo-audio-player__progress:hover,
.hailuo-audio-player__progress:focus-visible {
	opacity: 0.9;
}

.hailuo-audio-player__progress:hover::-webkit-slider-thumb,
.hailuo-audio-player__progress:focus-visible::-webkit-slider-thumb {
	opacity: 1;
}

.hailuo-audio-player__progress:hover::-moz-range-thumb,
.hailuo-audio-player__progress:focus-visible::-moz-range-thumb {
	opacity: 1;
}

.hailuo-audio-player__progress:disabled {
	cursor: default;
	opacity: 0.22;
}

.hailuo-audio-player__volume {
	position: relative;
	z-index: 2;
	display: flex;
	grid-column: 3;
	grid-row: 2;
	align-items: center;
	justify-self: end;
	gap: 0.55rem;
	width: min(9.5rem, 100%);
	color: #626269;
	opacity: 0.65;
	transition: opacity 150ms ease;
}

.hailuo-audio-player__volume:hover,
.hailuo-audio-player__volume:focus-within {
	opacity: 0.92;
}

.hailuo-audio-player__volume-icon {
	display: inline-grid;
	flex: 0 0 auto;
	width: 1.05rem;
	height: 1.05rem;
	place-items: center;
}

.hailuo-audio-player__volume-icon svg {
	display: block;
	width: 1.05rem;
	height: 1.05rem;
	stroke-width: 1.9;
}

.hailuo-audio-player__volume-range {
	display: block;
	flex: 1 1 auto;
	min-width: 4.5rem;
	height: 0.125rem;
	border-radius: 999px;
	appearance: none;
	background: linear-gradient(
		to right,
		rgba(86, 86, 92, 0.7) 0 var(--player-volume),
		rgba(86, 86, 92, 0.18) var(--player-volume) 100%
	);
	cursor: pointer;
}

.hailuo-audio-player__volume-range::-webkit-slider-thumb {
	width: 0.72rem;
	height: 0.72rem;
	border: 0;
	border-radius: 999px;
	appearance: none;
	background: rgba(86, 86, 92, 0.85);
	transition: transform 150ms ease;
}

.hailuo-audio-player__volume-range::-moz-range-thumb {
	width: 0.72rem;
	height: 0.72rem;
	border: 0;
	border-radius: 999px;
	background: rgba(86, 86, 92, 0.85);
	transition: transform 150ms ease;
}

.hailuo-audio-player__volume-range:hover::-webkit-slider-thumb,
.hailuo-audio-player__volume-range:focus-visible::-webkit-slider-thumb {
	transform: scale(1.12);
}

.hailuo-audio-player__volume-range:hover::-moz-range-thumb,
.hailuo-audio-player__volume-range:focus-visible::-moz-range-thumb {
	transform: scale(1.12);
}

.hailuo-audio-player__volume-range:disabled {
	cursor: default;
	opacity: 0.22;
}

.hailuo-audio-player__status {
	display: none;
	margin-top: 0.35rem;
	color: #dc2626;
	font-size: 0.8125rem;
	font-weight: 650;
}

.hailuo-audio-player__status.is-error {
	display: block;
}

html.dark .hailuo-audio-player {
	border-color: rgba(255, 255, 255, 0.12);
	background: rgba(35, 35, 40, 0.74);
	box-shadow:
		0 18px 40px rgba(0, 0, 0, 0.28),
		inset 0 1px 0 rgba(255, 255, 255, 0.08);
	color: rgba(255, 255, 255, 0.82);
}

html.dark .hailuo-audio-player__cover {
	border-color: rgba(255, 255, 255, 0.16);
	background: rgba(255, 255, 255, 0.08);
}

html.dark .hailuo-audio-player__title {
	color: rgba(255, 255, 255, 0.9);
}

html.dark .hailuo-audio-player__time,
html.dark .hailuo-audio-player__time-divider,
html.dark .hailuo-audio-player__button {
	color: rgba(255, 255, 255, 0.68);
}

html.dark .hailuo-audio-player__volume {
	color: rgba(255, 255, 255, 0.68);
}

html.dark .hailuo-audio-player__progress {
	background: linear-gradient(
		to right,
		rgba(255, 255, 255, 0.74) 0 var(--player-progress),
		rgba(255, 255, 255, 0.2) var(--player-progress) 100%
	);
}

html.dark .hailuo-audio-player__volume-range {
	background: linear-gradient(
		to right,
		rgba(255, 255, 255, 0.74) 0 var(--player-volume),
		rgba(255, 255, 255, 0.2) var(--player-volume) 100%
	);
}

html.dark .hailuo-audio-player__volume-range::-webkit-slider-thumb {
	background: rgba(255, 255, 255, 0.82);
}

html.dark .hailuo-audio-player__volume-range::-moz-range-thumb {
	background: rgba(255, 255, 255, 0.82);
}

html.dark .hailuo-audio-player__status.is-error {
	color: #fca5a5;
}

@media (max-width: 640px) {
	.hailuo-audio-player {
		grid-template-columns: auto minmax(0, 1fr) auto;
		grid-template-rows: auto auto auto;
		column-gap: 0.75rem;
		row-gap: 0.34rem;
		min-height: 4.65rem;
		padding: 0.7rem 0.8rem 0.85rem 0.7rem;
	}

	.hailuo-audio-player__cover {
		height: 3.25rem;
		max-width: min(6.5rem, 32vw);
		border-radius: 0.72rem;
	}

	.hailuo-audio-player__title {
		font-size: 1rem;
		line-height: 1.15;
	}

	.hailuo-audio-player__time-row {
		margin-top: 0.38rem;
	}

	.hailuo-audio-player__time,
	.hailuo-audio-player__time-divider {
		font-size: 0.86rem;
	}

	.hailuo-audio-player__controls {
		gap: 0.32rem;
		min-width: 8.9rem;
	}

	.hailuo-audio-player__button {
		width: 2rem;
		height: 2rem;
	}

	.hailuo-audio-player__button svg {
		width: 1.55rem;
		height: 1.55rem;
	}

	.hailuo-audio-player__progress {
		grid-column: 2 / 4;
		grid-row: 2;
		width: 100%;
	}

	.hailuo-audio-player__volume {
		grid-column: 2 / 4;
		grid-row: 3;
		gap: 0.45rem;
		width: 100%;
	}

	.hailuo-audio-player__volume-icon,
	.hailuo-audio-player__volume-icon svg {
		width: 0.95rem;
		height: 0.95rem;
	}

	.hailuo-audio-player__volume-range {
		min-width: 0;
	}
}
</style>

<script>
const ICONS = {
	play: `<svg viewBox="0 0 32 32" aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M11 7.5v17l14-8.5-14-8.5Z"/></svg>`,
	pause: `<svg viewBox="0 0 32 32" aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M11 8v16"/><path d="M21 8v16"/></svg>`,
	previous: `<svg viewBox="0 0 32 32" aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M8 7v18"/><path d="M24 7.5 11 16l13 8.5V7.5Z"/></svg>`,
	next: `<svg viewBox="0 0 32 32" aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M24 7v18"/><path d="M8 7.5 21 16 8 24.5V7.5Z"/></svg>`,
	repeat: `<svg viewBox="0 0 32 32" aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M7 10.5h14.5a4.5 4.5 0 0 1 4.5 4.5v1"/><path d="m22.5 6.5 4 4-4 4"/><path d="M25 21.5H10.5A4.5 4.5 0 0 1 6 17v-1"/><path d="m9.5 25.5-4-4 4-4"/></svg>`,
	volume: `<svg viewBox="0 0 32 32" aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M7 13v8h5l7 5V8l-7 5H7Z"/><path d="M23 12.5a6 6 0 0 1 0 7"/></svg>`,
	volumeMuted: `<svg viewBox="0 0 32 32" aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M7 13v8h5l7 5V8l-7 5H7Z"/><path d="m23.5 13.5 5 5"/><path d="m28.5 13.5-5 5"/></svg>`,
};
const UI_TEXT = {
	untitled: "Untitled track",
	source: "Source",
	play: "\u64ad\u653e\u97f3\u4e50",
	pause: "\u6682\u505c\u97f3\u4e50",
	previous: "\u4e0a\u4e00\u9996\uff08\u5355\u66f2\u64ad\u653e\u5668\u6682\u4e0d\u53ef\u7528\uff09",
	next: "\u4e0b\u4e00\u9996\uff08\u5355\u66f2\u64ad\u653e\u5668\u6682\u4e0d\u53ef\u7528\uff09",
	repeat: "\u5faa\u73af\uff08\u5355\u66f2\u64ad\u653e\u5668\u6682\u4e0d\u53ef\u7528\uff09",
	progress: "\u64ad\u653e\u8fdb\u5ea6",
	volume: "\u97f3\u91cf",
	cover: "\u4e13\u8f91\u5c01\u9762",
	loading: "\u52a0\u8f7d\u4e2d",
	error: "\u97f3\u9891\u52a0\u8f7d\u5931\u8d25",
};

function formatAudioTime(seconds: number) {
	if (!Number.isFinite(seconds) || seconds < 0) return "0:00";

	const totalSeconds = Math.floor(seconds);
	const minutes = Math.floor(totalSeconds / 60);
	const remainingSeconds = totalSeconds % 60;

	return `${minutes.toString().padStart(2, "0")}:${remainingSeconds.toString().padStart(2, "0")}`;
}

class HailuoAudioPlayer extends HTMLElement {
	private audio?: HTMLAudioElement;
	private button?: HTMLButtonElement;
	private progress?: HTMLInputElement;
	private volume?: HTMLInputElement;
	private volumeIcon?: HTMLSpanElement;
	private currentTime?: HTMLSpanElement;
	private durationTime?: HTMLSpanElement;
	private status?: HTMLSpanElement;
	private wrapper?: HTMLDivElement;
	private isSeeking = false;

	connectedCallback() {
		if (this.dataset.initialized === "true") return;
		this.dataset.initialized = "true";
		this.render();
	}

	private getSources() {
		const mp3 = this.getAttribute("mp3")?.trim() || "";
		const flac = this.getAttribute("flac")?.trim() || "";
		const src = this.getAttribute("src")?.trim() || "";
		const type = this.getAttribute("type")?.trim() || "";
		const sources: Array<{ src: string; type: string; label: string }> = [];

		if (mp3) sources.push({ src: mp3, type: "audio/mpeg", label: "MP3" });
		if (flac) sources.push({ src: flac, type: "audio/flac", label: "FLAC" });
		if (!sources.length && src) {
			sources.push({ src, type: type || "", label: UI_TEXT.source });
		}

		return sources;
	}

	private createIconButton(icon: keyof typeof ICONS, label: string, disabled = false) {
		const button = document.createElement("button");
		button.type = "button";
		button.className = "hailuo-audio-player__button";
		button.innerHTML = ICONS[icon];
		button.setAttribute("aria-label", label);
		if (disabled) {
			button.disabled = true;
			button.setAttribute("aria-disabled", "true");
		}

		return button;
	}

	private renderCover(title: string) {
		const cover = this.getAttribute("cover")?.trim() || "";
		const coverWrap = document.createElement("div");
		coverWrap.className = "hailuo-audio-player__cover";

		if (cover) {
			const image = document.createElement("img");
			image.className = "hailuo-audio-player__cover-image";
			image.alt = `${title} ${UI_TEXT.cover}`;
			image.loading = "lazy";
			image.decoding = "async";
			image.addEventListener("load", () => this.updateCoverRatio(coverWrap, image));
			image.addEventListener("error", () => {
				coverWrap.textContent = "";
				const fallback = document.createElement("div");
				fallback.className = "hailuo-audio-player__cover-fallback";
				fallback.textContent = "\u266b";
				coverWrap.appendChild(fallback);
			});
			image.src = cover;
			if (image.complete) this.updateCoverRatio(coverWrap, image);
			coverWrap.appendChild(image);
			return coverWrap;
		}

		const fallback = document.createElement("div");
		fallback.className = "hailuo-audio-player__cover-fallback";
		fallback.textContent = "\u266b";
		coverWrap.appendChild(fallback);

		return coverWrap;
	}

	private updateCoverRatio(coverWrap: HTMLDivElement, image: HTMLImageElement) {
		const { naturalWidth, naturalHeight } = image;
		if (naturalWidth <= 0 || naturalHeight <= 0) return;

		coverWrap.style.setProperty("--cover-aspect-ratio", `${naturalWidth} / ${naturalHeight}`);
	}

	private render() {
		const sources = this.getSources();
		const title = this.getAttribute("title")?.trim() || UI_TEXT.untitled;
		const artist = this.getAttribute("artist")?.trim() || "";

		this.textContent = "";

		this.wrapper = document.createElement("div");
		this.wrapper.className = "hailuo-audio-player";

		const cover = this.renderCover(title);
		const main = document.createElement("div");
		main.className = "hailuo-audio-player__main";

		const meta = document.createElement("div");
		meta.className = "hailuo-audio-player__meta";

		const titleEl = document.createElement("div");
		titleEl.className = "hailuo-audio-player__title";
		titleEl.textContent = title;
		titleEl.title = artist ? `${title} - ${artist}` : title;
		meta.appendChild(titleEl);

		const timeRow = document.createElement("div");
		timeRow.className = "hailuo-audio-player__time-row";

		this.currentTime = document.createElement("span");
		this.currentTime.className = "hailuo-audio-player__time";
		this.currentTime.textContent = "00:00";

		const timeDivider = document.createElement("span");
		timeDivider.className = "hailuo-audio-player__time-divider";
		timeDivider.textContent = "/";

		this.durationTime = document.createElement("span");
		this.durationTime.className = "hailuo-audio-player__time";
		this.durationTime.textContent = "00:00";

		timeRow.append(this.currentTime, timeDivider, this.durationTime);
		meta.appendChild(timeRow);

		const controls = document.createElement("div");
		controls.className = "hailuo-audio-player__controls";

		const previousButton = this.createIconButton("previous", UI_TEXT.previous, true);
		const nextButton = this.createIconButton("next", UI_TEXT.next, true);
		const repeatButton = this.createIconButton("repeat", UI_TEXT.repeat, true);

		this.button = this.createIconButton("play", UI_TEXT.play);
		this.button.setAttribute("aria-pressed", "false");
		this.button.disabled = sources.length === 0;

		this.progress = document.createElement("input");
		this.progress.className = "hailuo-audio-player__progress";
		this.progress.type = "range";
		this.progress.min = "0";
		this.progress.max = "1000";
		this.progress.value = "0";
		this.progress.step = "1";
		this.progress.setAttribute("aria-label", UI_TEXT.progress);
		this.progress.disabled = sources.length === 0;

		controls.append(previousButton, this.button, nextButton, repeatButton);

		const volumeControl = document.createElement("div");
		volumeControl.className = "hailuo-audio-player__volume";

		this.volumeIcon = document.createElement("span");
		this.volumeIcon.className = "hailuo-audio-player__volume-icon";
		this.volumeIcon.setAttribute("aria-hidden", "true");
		this.volumeIcon.innerHTML = ICONS.volume;

		this.volume = document.createElement("input");
		this.volume.className = "hailuo-audio-player__volume-range";
		this.volume.type = "range";
		this.volume.min = "0";
		this.volume.max = "100";
		this.volume.value = "100";
		this.volume.step = "1";
		this.volume.setAttribute("aria-label", UI_TEXT.volume);
		this.volume.disabled = sources.length === 0;

		volumeControl.append(this.volumeIcon, this.volume);

		this.status = document.createElement("span");
		this.status.className = "hailuo-audio-player__status";
		this.status.setAttribute("aria-live", "polite");

		main.append(meta, this.status);

		this.audio = document.createElement("audio");
		this.audio.preload = "metadata";
		this.audio.volume = this.getVolumePercent() / 100;
		for (const source of sources) {
			const sourceEl = document.createElement("source");
			sourceEl.src = source.src;
			if (source.type) sourceEl.type = source.type;
			this.audio.appendChild(sourceEl);
		}

		this.wrapper.append(cover, main, controls, this.progress, volumeControl, this.audio);
		this.appendChild(this.wrapper);

		this.bindEvents();
		this.updateProgress();
		this.updateVolumeFill();
	}

	private bindEvents() {
		if (!this.audio || !this.button || !this.progress || !this.volume) return;

		this.button.addEventListener("click", () => this.togglePlayback());
		this.progress.addEventListener("input", () => this.handleSeekInput());
		this.progress.addEventListener("change", () => this.commitSeek());
		this.volume.addEventListener("input", () => this.handleVolumeInput());

		this.audio.addEventListener("loadedmetadata", () => this.updateProgress());
		this.audio.addEventListener("durationchange", () => this.updateProgress());
		this.audio.addEventListener("timeupdate", () => this.updateProgress());
		this.audio.addEventListener("volumechange", () => this.syncVolumeFromAudio());
		this.audio.addEventListener("play", () => {
			this.clearError();
			this.updatePlayingState(true);
		});
		this.audio.addEventListener("pause", () => this.updatePlayingState(false));
		this.audio.addEventListener("ended", () => this.updatePlayingState(false));
		this.audio.addEventListener("error", () => this.showError());
	}

	private async togglePlayback() {
		if (!this.audio || !this.button) return;

		if (this.audio.paused) {
			try {
				this.button.disabled = true;
				this.button.classList.add("is-loading");
				this.clearError();
				await this.audio.play();
			} catch {
				this.showError();
			} finally {
				this.button.disabled = false;
				this.button.classList.remove("is-loading");
			}
			return;
		}

		this.audio.pause();
	}

	private handleSeekInput() {
		if (!this.audio || !this.progress || !Number.isFinite(this.audio.duration)) return;

		this.isSeeking = true;
		const nextTime = (Number(this.progress.value) / 1000) * this.audio.duration;
		if (this.currentTime) this.currentTime.textContent = formatAudioTime(nextTime);
		this.updateProgressFill();
	}

	private handleVolumeInput() {
		if (!this.audio || !this.volume) return;

		const volume = this.getVolumePercent() / 100;
		this.audio.volume = volume;
		this.audio.muted = volume === 0;
		this.updateVolumeFill();
	}

	private syncVolumeFromAudio() {
		if (!this.audio || !this.volume) return;

		const volume = this.audio.muted ? 0 : this.audio.volume * 100;
		this.volume.value = String(Math.round(volume));
		this.updateVolumeFill();
	}

	private getVolumePercent() {
		const value = Number(this.volume?.value ?? 100);
		if (!Number.isFinite(value)) return 100;

		return Math.max(0, Math.min(100, value));
	}

	private commitSeek() {
		if (!this.audio || !this.progress || !Number.isFinite(this.audio.duration)) return;

		this.audio.currentTime = (Number(this.progress.value) / 1000) * this.audio.duration;
		this.isSeeking = false;
		this.updateProgress();
	}

	private updatePlayingState(isPlaying: boolean) {
		if (!this.button) return;

		this.button.innerHTML = isPlaying ? ICONS.pause : ICONS.play;
		this.button.setAttribute("aria-label", isPlaying ? UI_TEXT.pause : UI_TEXT.play);
		this.button.setAttribute("aria-pressed", String(isPlaying));
		this.button.classList.toggle("is-playing", isPlaying);
	}

	private updateProgress() {
		if (!this.audio || !this.progress || !this.currentTime || !this.durationTime) return;

		const duration = this.audio.duration;
		const currentTime = this.audio.currentTime;

		this.currentTime.textContent = formatAudioTime(currentTime);
		this.durationTime.textContent = formatAudioTime(duration);

		if (!this.isSeeking && Number.isFinite(duration) && duration > 0) {
			this.progress.value = String(Math.round((currentTime / duration) * 1000));
		}
		this.updateProgressFill();
	}

	private updateProgressFill() {
		if (!this.wrapper || !this.progress) return;

		const progress = Math.max(0, Math.min(100, Number(this.progress.value) / 10));
		this.wrapper.style.setProperty("--player-progress", `${progress}%`);
	}

	private updateVolumeFill() {
		if (!this.wrapper || !this.volume) return;

		const volume = this.getVolumePercent();
		this.volume.value = String(Math.round(volume));
		this.wrapper.style.setProperty("--player-volume", `${volume}%`);
		if (this.volumeIcon) this.volumeIcon.innerHTML = volume === 0 ? ICONS.volumeMuted : ICONS.volume;
	}

	private clearError() {
		if (!this.status) return;

		this.status.textContent = "";
		this.status.classList.remove("is-error");
	}

	private showError() {
		if (this.status) {
			this.status.textContent = UI_TEXT.error;
			this.status.classList.add("is-error");
		}
		if (this.button) {
			this.button.innerHTML = ICONS.play;
			this.button.setAttribute("aria-label", UI_TEXT.play);
			this.button.setAttribute("aria-pressed", "false");
			this.button.classList.remove("is-playing");
			this.button.classList.remove("is-loading");
		}
	}
}

if (!customElements.get("hailuo-audio-player")) {
	customElements.define("hailuo-audio-player", HailuoAudioPlayer);
}
</script>
