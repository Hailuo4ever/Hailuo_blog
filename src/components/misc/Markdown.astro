---
import "@fontsource-variable/cascadia-code";
import "@fontsource-variable/cascadia-code/wght-italic.css";
import "@fontsource-variable/jetbrains-mono";
import "@fontsource-variable/jetbrains-mono/wght-italic.css";

interface Props {
	class: string;
}
const className = Astro.props.class;
---
<div data-pagefind-body class={`prose dark:prose-invert prose-base !max-w-none custom-md ${className}`}>
    <!--<div class="prose dark:prose-invert max-w-none custom-md">-->
    <!--<div class="max-w-none custom-md">-->
    <slot/>
</div>

<script>
function ensureExpressiveCodeAssets() {
    document
        .querySelectorAll<HTMLStyleElement>(".expressive-code style")
        .forEach((style, styleIndex) => {
            const styleId = `expressive-code-inline-style-${styleIndex}`;
            if (document.head.querySelector(`#${styleId}`)) return;

            const headStyle = document.createElement("style");
            headStyle.id = styleId;
            headStyle.textContent = style.textContent;
            document.head.appendChild(headStyle);
        });

    document
        .querySelectorAll<HTMLLinkElement>(".expressive-code link[rel='stylesheet'][href]")
        .forEach((link) => {
            if (document.head.querySelector(`link[rel="stylesheet"][href="${link.href}"]`)) return;

            const headLink = document.createElement("link");
            headLink.rel = "stylesheet";
            headLink.href = link.href;
            document.head.appendChild(headLink);
        });

    document
        .querySelectorAll<HTMLScriptElement>(".expressive-code script[type='module'][src]")
        .forEach((script) => {
            if (document.head.querySelector(`script[type="module"][src="${script.src}"]`)) return;

            const headScript = document.createElement("script");
            headScript.type = "module";
            headScript.src = script.src;
            document.head.appendChild(headScript);
        });
}

function initHeadingCollapse() {
    ensureExpressiveCodeAssets();

    const markdownBlocks = document.querySelectorAll<HTMLElement>(".markdown-content");

    markdownBlocks.forEach((markdownBlock) => {
        const sections = markdownBlock.querySelectorAll<HTMLElement>("section");

        sections.forEach((section) => {
            if (section.dataset.headingCollapseInitialized === "true") return;

            const heading = section.firstElementChild;
            if (!(heading instanceof HTMLHeadingElement)) return;
            if (!/^H[1-6]$/.test(heading.tagName)) return;

            const button = document.createElement("button");
            button.type = "button";
            button.className = "heading-collapse-toggle";
            button.setAttribute("aria-expanded", "true");
            button.setAttribute("aria-label", "Collapse section");
            button.setAttribute("data-pagefind-ignore", "true");

            button.addEventListener("click", () => {
                const isCollapsed = section.classList.toggle("heading-collapsed");
                button.setAttribute("aria-expanded", String(!isCollapsed));
                button.setAttribute("aria-label", isCollapsed ? "Expand section" : "Collapse section");
                window.dispatchEvent(new CustomEvent("heading-collapse:change"));
            });

            heading.prepend(button);
            section.dataset.headingCollapseInitialized = "true";
        });
    });
}

initHeadingCollapse();

const setupHeadingCollapse = () => {
    window.swup.hooks.on("page:view", initHeadingCollapse);
};

const headingCollapseWindow = window as Window & {
    headingCollapseSetup?: boolean;
};

if (!headingCollapseWindow.headingCollapseSetup) {
    headingCollapseWindow.headingCollapseSetup = true;
    if (window.swup) {
        setupHeadingCollapse();
    } else {
        document.addEventListener("swup:enable", setupHeadingCollapse, { once: true });
    }
}

const katexAnnotationSelector = 'annotation[encoding="application/x-tex"]';
const markdownKatexSelector = ".custom-md .katex-display, .custom-md .katex";
const blockTags = new Set([
    "ADDRESS",
    "ARTICLE",
    "ASIDE",
    "BLOCKQUOTE",
    "DD",
    "DIV",
    "DL",
    "DT",
    "FIGCAPTION",
    "FIGURE",
    "FOOTER",
    "FORM",
    "H1",
    "H2",
    "H3",
    "H4",
    "H5",
    "H6",
    "HEADER",
    "HR",
    "LI",
    "MAIN",
    "NAV",
    "OL",
    "P",
    "PRE",
    "SECTION",
    "TABLE",
    "TBODY",
    "TD",
    "TFOOT",
    "TH",
    "THEAD",
    "TR",
    "UL",
]);

function getKatexSource(element: Element) {
    const annotation = element.querySelector<HTMLElement>(katexAnnotationSelector);
    return annotation?.textContent?.trim() || null;
}

function formatKatexSource(element: Element) {
    const source = getKatexSource(element);
    if (!source) return null;

    if (element.classList.contains("katex-display")) {
        return `\n$$\n${source}\n$$\n`;
    }

    return `$${source}$`;
}

function selectionContainsMarkdownKatex(selection: Selection) {
    const range = selection.getRangeAt(0);
    const katexElements = document.querySelectorAll<HTMLElement>(markdownKatexSelector);

    for (const element of katexElements) {
        if (element.closest("pre, code")) continue;
        if (element.classList.contains("katex") && element.closest(".katex-display")) continue;

        try {
            if (range.intersectsNode(element)) return true;
        } catch {
            continue;
        }
    }

    return false;
}

function getKatexRoot(node: Node) {
    const element = node instanceof Element ? node : node.parentElement;
    if (!element) return null;

    return element.closest<HTMLElement>(".katex-display") ?? element.closest<HTMLElement>(".katex");
}

function isStandaloneKatexRoot(element: Element) {
    return element.classList.contains("katex-display") || (element.classList.contains("katex") && !element.closest(".katex-display"));
}

function rangeIntersectsNode(range: Range, node: Node) {
    try {
        return range.intersectsNode(node);
    } catch {
        return false;
    }
}

function getRangeRoot(range: Range) {
    const commonAncestor = range.commonAncestorContainer;
    const commonElement = commonAncestor instanceof Element ? commonAncestor : commonAncestor.parentElement;

    return commonElement?.closest<HTMLElement>(".custom-md") ?? document.body;
}

function getSelectedTextFromTextNode(range: Range, node: Text) {
    const text = node.textContent ?? "";
    const start = node === range.startContainer ? range.startOffset : 0;
    const end = node === range.endContainer ? range.endOffset : text.length;

    return text.slice(start, end);
}

function serializeSelectedNode(range: Range, node: Node, copiedKatexRoots: Set<Element>): string | null {
    if (!rangeIntersectsNode(range, node)) return "";

    const katexRoot = getKatexRoot(node);
    if (katexRoot && isStandaloneKatexRoot(katexRoot)) {
        if (copiedKatexRoots.has(katexRoot)) return "";
        copiedKatexRoots.add(katexRoot);

        return formatKatexSource(katexRoot);
    }

    if (node.nodeType === Node.TEXT_NODE) {
        return getSelectedTextFromTextNode(range, node as Text);
    }

    if (!(node instanceof Element)) {
        let text = "";
        for (const child of Array.from(node.childNodes)) {
            const childText = serializeSelectedNode(range, child, copiedKatexRoots);
            if (childText === null) return null;
            text += childText;
        }

        return text;
    }

    if (node.tagName === "BR") return "\n";

    let text = "";
    for (const child of Array.from(node.childNodes)) {
        const childText = serializeSelectedNode(range, child, copiedKatexRoots);
        if (childText === null) return null;
        text += childText;
    }

    if (!blockTags.has(node.tagName)) return text;

    return `\n${text}\n`;
}

function normalizeCopiedText(text: string) {
    return text
        .replace(/\u00a0/g, " ")
        .replace(/[ \t]+\n/g, "\n")
        .replace(/\n[ \t]+/g, "\n")
        .replace(/\n{3,}/g, "\n\n")
        .trim();
}

function getFormulaCopyText(range: Range) {
    const root = getRangeRoot(range);
    const copiedKatexRoots = new Set<Element>();
    const copiedText = serializeSelectedNode(range, root, copiedKatexRoots);

    if (copiedText === null || copiedKatexRoots.size === 0) return null;

    return normalizeCopiedText(copiedText);
}

function handleFormulaCopy(event: ClipboardEvent) {
    const selection = window.getSelection();
    if (!selection || selection.rangeCount === 0 || selection.isCollapsed) return;
    if (!selectionContainsMarkdownKatex(selection)) return;

    const copiedText = getFormulaCopyText(selection.getRangeAt(0));
    if (!copiedText || !event.clipboardData) return;

    event.clipboardData.setData("text/plain", copiedText);
    event.preventDefault();
}

const formulaCopyWindow = window as Window & {
    formulaCopySetup?: boolean;
};

if (!formulaCopyWindow.formulaCopySetup) {
    formulaCopyWindow.formulaCopySetup = true;
    document.addEventListener("copy", handleFormulaCopy);
}

document.addEventListener("click", function (e: MouseEvent) {
    const target = e.target as Element | null;
    if (target && target.classList.contains("copy-btn")) {
        const preEle = target.closest("pre");
        const codeEle = preEle?.querySelector("code");
        const code = Array.from(codeEle?.querySelectorAll(".code:not(summary *)") ?? [])
            .map(el => el.textContent)
            .map(t => t === "\n" ? "" : t)
            .join("\n");
        navigator.clipboard.writeText(code);

        const timeoutId = target.getAttribute("data-timeout-id");
        if (timeoutId) {
            clearTimeout(parseInt(timeoutId));
        }

        target.classList.add("success");

        // 设置新的timeout并保存ID到按钮的自定义属性中
        const newTimeoutId = setTimeout(() => {
            target.classList.remove("success");
        }, 1000);

        target.setAttribute("data-timeout-id", newTimeoutId.toString());
    }
});
</script>
