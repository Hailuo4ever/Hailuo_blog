---
import path from "node:path";
import License from "@components/misc/License.astro";
import Markdown from "@components/misc/Markdown.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedPosts } from "@utils/content-utils";
import { getDir, getPostUrlBySlug } from "@utils/url-utils";
import { Icon } from "astro-icon/components";
import { licenseConfig } from "src/config";
import ImageWrapper from "../../components/misc/ImageWrapper.astro";
import PostMetadata from "../../components/PostMeta.astro";
import { profileConfig, siteConfig } from "../../config";
import { formatDateToYYYYMMDD } from "../../utils/date-utils";

export async function getStaticPaths() {
	const blogEntries = await getSortedPosts();
	return blogEntries.map((entry) => ({
		params: { slug: entry.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();

const { remarkPluginFrontmatter } = await entry.render();

const BIRTHDAY_POST_SLUG = "diary/260608";
const isBirthdayPost = entry.slug === BIRTHDAY_POST_SLUG;

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	headline: entry.data.title,
	description: entry.data.description || entry.data.title,
	keywords: entry.data.tags,
	author: {
		"@type": "Person",
		name: profileConfig.name,
		url: Astro.site,
	},
	datePublished: formatDateToYYYYMMDD(entry.data.published),
	inLanguage: entry.data.lang
		? entry.data.lang.replace("_", "-")
		: siteConfig.lang.replace("_", "-"),
	// TODO include cover image here
};
---
<MainGridLayout banner={entry.data.image} title={entry.data.title} description={entry.data.description} lang={entry.data.lang} setOGTypeArticle={true} headings={headings}>
    <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
    <div class:list={[
        "flex w-full rounded-[var(--radius-large)] overflow-hidden relative mb-4",
        {"birthday-post-page": isBirthdayPost},
    ]} data-birthday-post={isBirthdayPost ? "true" : undefined}>
        <div id="post-container" class:list={["card-base z-10 px-6 md:px-9 pt-6 pb-4 relative w-full ",
            {"birthday-post-container": isBirthdayPost}
        ]}>
            {isBirthdayPost && (
                <div class="birthday-decorations" aria-hidden="true">
                    <span></span>
                    <span></span>
                    <span></span>
                    <span></span>
                    <span></span>
                    <span></span>
                    <span></span>
                    <span></span>
                    <span></span>
                    <span></span>
                    <span></span>
                    <span></span>
                </div>
            )}

            <!-- word count and reading time -->
            <div class="flex flex-row text-black/30 dark:text-white/30 gap-5 mb-3 transition onload-animation">
                <div class="flex flex-row items-center">
                    <div class="transition h-6 w-6 rounded-md bg-black/5 dark:bg-white/10 text-black/50 dark:text-white/50 flex items-center justify-center mr-2">
                        <Icon name="material-symbols:notes-rounded"></Icon>
                    </div>
                    <div class="text-sm">{remarkPluginFrontmatter.words} {" " + i18n(I18nKey.wordsCount)}</div>
                </div>
                <div class="flex flex-row items-center">
                    <div class="transition h-6 w-6 rounded-md bg-black/5 dark:bg-white/10 text-black/50 dark:text-white/50 flex items-center justify-center mr-2">
                        <Icon name="material-symbols:schedule-outline-rounded"></Icon>
                    </div>
                    <div class="text-sm">
                        {remarkPluginFrontmatter.minutes} {" " + i18n(remarkPluginFrontmatter.minutes === 1 ? I18nKey.minuteCount : I18nKey.minutesCount)}
                    </div>
                </div>
            </div>

            <!-- title -->
            <div class="relative onload-animation">
                <div
                    data-pagefind-body data-pagefind-weight="10" data-pagefind-meta="title"
                    class="transition w-full block font-bold mb-3
                    text-3xl md:text-[2.25rem]/[2.75rem]
                    text-black/90 dark:text-white/90
                    md:before:w-1 before:h-5 before:rounded-md before:bg-[var(--primary)]
                    before:absolute before:top-[0.75rem] before:left-[-1.125rem]
                ">
                    {entry.data.title}
                    {entry.data.status === "editing" && (
                        <span class="ml-3 inline-flex align-middle translate-y-[-0.35rem] rounded-md border border-[var(--primary)]/30 bg-[var(--primary)]/10 px-2 py-1 text-sm font-semibold text-[var(--primary)]">
                            {i18n(I18nKey.editing)}
                        </span>
                    )}
                </div>
            </div>

            <!-- metadata -->
            <div class="onload-animation">
                <PostMetadata
                        class="mb-5"
                        published={entry.data.published}
                        updated={entry.data.updated}
                        status={entry.data.status}
                        tags={entry.data.tags}
                        category={entry.data.category}
                ></PostMetadata>
                {!entry.data.image && <div class="border-[var(--line-divider)] border-dashed border-b-[1px] mb-5"></div>}
            </div>

            <!-- always show cover as long as it has one -->

            {entry.data.image &&
                <ImageWrapper id="post-cover" src={entry.data.image} basePath={path.join("content/posts/", getDir(entry.id))} class="mb-8 rounded-xl banner-container onload-animation"/>
            }


            <Markdown class="mb-6 markdown-content onload-animation">
                <Content />
            </Markdown>

            {licenseConfig.enable && <License title={entry.data.title} slug={entry.slug} pubDate={entry.data.published} class="mb-6 rounded-xl license-container onload-animation"></License>}

        </div>
    </div>

    <div class="flex flex-col md:flex-row justify-between mb-4 gap-4 overflow-hidden w-full">
        <a href={entry.data.nextSlug ? getPostUrlBySlug(entry.data.nextSlug) : "#"}
           class:list={["w-full font-bold overflow-hidden active:scale-95", {"pointer-events-none": !entry.data.nextSlug}]}>
            {entry.data.nextSlug && <div class="btn-card rounded-2xl w-full h-[3.75rem] max-w-full px-4 flex items-center !justify-start gap-4" >
                <Icon name="material-symbols:chevron-left-rounded" class="text-[2rem] text-[var(--primary)]" />
                <div class="overflow-hidden transition overflow-ellipsis whitespace-nowrap max-w-[calc(100%_-_3rem)] text-black/75 dark:text-white/75">
                    {entry.data.nextTitle}
                </div>
            </div>}
        </a>

        <a href={entry.data.prevSlug ? getPostUrlBySlug(entry.data.prevSlug) : "#"}
           class:list={["w-full font-bold overflow-hidden active:scale-95", {"pointer-events-none": !entry.data.prevSlug}]}>
            {entry.data.prevSlug && <div class="btn-card rounded-2xl w-full h-[3.75rem] max-w-full px-4 flex items-center !justify-end gap-4">
                <div class="overflow-hidden transition overflow-ellipsis whitespace-nowrap max-w-[calc(100%_-_3rem)] text-black/75 dark:text-white/75">
                    {entry.data.prevTitle}
                </div>
                <Icon name="material-symbols:chevron-right-rounded" class="text-[2rem] text-[var(--primary)]" />
            </div>}
        </a>
    </div>

</MainGridLayout>

<style is:global>
html:has(.birthday-post-page) {
	--page-bg: #fff7ea;
}

html.dark:has(.birthday-post-page) {
	--page-bg: #151827;
}

.birthday-post-page {
	isolation: isolate;
	overflow: visible;
}

.birthday-post-page::before {
	position: absolute;
	inset: -1rem -0.75rem;
	z-index: -2;
	border: 1px solid rgba(244, 180, 75, 0.24);
	border-radius: var(--radius-large);
	background:
		linear-gradient(135deg, rgba(255, 247, 232, 0.96), rgba(235, 247, 255, 0.92) 48%, rgba(255, 239, 248, 0.94));
	box-shadow:
		0 24px 70px rgba(244, 146, 53, 0.16),
		inset 0 1px 0 rgba(255, 255, 255, 0.82);
	content: "";
}

.birthday-post-page::after {
	position: absolute;
	inset: -0.5rem;
	z-index: -1;
	border-radius: var(--radius-large);
	background-image:
		linear-gradient(90deg, rgba(239, 93, 168, 0.26) 0 7px, transparent 7px 100%),
		linear-gradient(0deg, rgba(56, 189, 248, 0.2) 0 6px, transparent 6px 100%),
		linear-gradient(45deg, rgba(250, 204, 21, 0.24) 0 5px, transparent 5px 100%),
		linear-gradient(135deg, rgba(52, 211, 153, 0.2) 0 5px, transparent 5px 100%);
	background-position:
		12px 22px,
		54px 10px,
		28px 72px,
		86px 42px;
	background-size:
		112px 112px,
		132px 132px,
		96px 96px,
		148px 148px;
	content: "";
	mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.82), rgba(0, 0, 0, 0.18));
	pointer-events: none;
}

html.dark .birthday-post-page::before {
	border-color: rgba(96, 165, 250, 0.24);
	background:
		linear-gradient(135deg, rgba(28, 31, 50, 0.96), rgba(20, 41, 52, 0.9) 48%, rgba(48, 28, 45, 0.92));
	box-shadow:
		0 24px 70px rgba(6, 10, 24, 0.46),
		inset 0 1px 0 rgba(255, 255, 255, 0.06);
}

.birthday-post-container.card-base {
	border: 1px solid rgba(244, 180, 75, 0.28);
	background: rgba(255, 255, 255, 0.9);
	box-shadow:
		0 18px 48px rgba(249, 115, 22, 0.1),
		inset 0 1px 0 rgba(255, 255, 255, 0.88);
	backdrop-filter: blur(18px);
}

.birthday-post-container::before {
	position: absolute;
	top: 0;
	right: 0;
	left: 0;
	height: 4px;
	background: linear-gradient(90deg, #facc15, #ef5da8, #38bdf8, #34d399);
	content: "";
}

html.dark .birthday-post-container.card-base {
	border-color: rgba(96, 165, 250, 0.25);
	background: rgba(25, 28, 47, 0.88);
	box-shadow:
		0 18px 48px rgba(0, 0, 0, 0.28),
		inset 0 1px 0 rgba(255, 255, 255, 0.06);
}

.birthday-decorations {
	position: absolute;
	inset: 0;
	z-index: 1;
	overflow: hidden;
	border-radius: inherit;
	pointer-events: none;
}

.birthday-decorations span {
	position: absolute;
	width: 0.42rem;
	height: 1rem;
	border-radius: 0.16rem;
	opacity: 0.54;
	transform: rotate(var(--birthday-confetti-angle));
}

.birthday-decorations span:nth-child(1) {
	top: 1.4rem;
	left: 1.2rem;
	--birthday-confetti-angle: -22deg;
	background: #ef5da8;
}

.birthday-decorations span:nth-child(2) {
	top: 3.2rem;
	left: 4.8rem;
	--birthday-confetti-angle: 32deg;
	background: #38bdf8;
}

.birthday-decorations span:nth-child(3) {
	top: 1.8rem;
	right: 3.8rem;
	--birthday-confetti-angle: 18deg;
	background: #facc15;
}

.birthday-decorations span:nth-child(4) {
	top: 5.6rem;
	right: 1.6rem;
	--birthday-confetti-angle: -38deg;
	background: #34d399;
}

.birthday-decorations span:nth-child(5) {
	top: 12rem;
	left: 1.5rem;
	--birthday-confetti-angle: 56deg;
	background: #f97316;
}

.birthday-decorations span:nth-child(6) {
	top: 17rem;
	right: 2.6rem;
	--birthday-confetti-angle: 21deg;
	background: #a78bfa;
}

.birthday-decorations span:nth-child(7) {
	bottom: 18rem;
	left: 2.8rem;
	--birthday-confetti-angle: -14deg;
	background: #38bdf8;
}

.birthday-decorations span:nth-child(8) {
	right: 4.8rem;
	bottom: 14rem;
	--birthday-confetti-angle: 44deg;
	background: #ef5da8;
}

.birthday-decorations span:nth-child(9) {
	bottom: 8rem;
	left: 1.1rem;
	--birthday-confetti-angle: 18deg;
	background: #34d399;
}

.birthday-decorations span:nth-child(10) {
	right: 1.4rem;
	bottom: 6rem;
	--birthday-confetti-angle: -28deg;
	background: #facc15;
}

.birthday-decorations span:nth-child(11) {
	top: 26rem;
	left: 5.6rem;
	--birthday-confetti-angle: 39deg;
	background: #a78bfa;
}

.birthday-decorations span:nth-child(12) {
	top: 30rem;
	right: 6.2rem;
	--birthday-confetti-angle: -12deg;
	background: #f97316;
}

@media (max-width: 640px) {
	.birthday-post-page::before {
		inset: -0.5rem 0;
	}

	.birthday-post-page::after {
		inset: 0;
		background-size:
			92px 92px,
			108px 108px,
			84px 84px,
			120px 120px;
	}
}
</style>
